pipeline {
  agent any

  stages {
    stage('Clone') {
      steps {
        git 'https://github.com/JULIET-JULIET632/devops-project.git'
      }
    }

    stage('Build Docker Image') {
      steps {
        sh 'docker build -t juliet237/devops-app:latest .'
      }
    }

    stage('Push Image') {
      steps {
        sh 'docker push juliet237/devops-app:latest'
      }
    }
  }
}
